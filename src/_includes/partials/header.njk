<header>
  <a href="/" class="logo">
    <img src="/assets/images/callteam-logo.png" alt="{{ site.name }}">
  </a>

  <input type="checkbox" id="menu-toggle" class="menu-toggle">

  <nav class="nav-links">
    {% for item in navigation %}
      <a href="{{ item.url }}">{{ item.label }}</a>
    {% endfor %}
  </nav>

  <div class="header-right">
    <a href="https://calendly.com/hello-callteam/30min" class="header-cta" target="_blank" rel="noopener">{{ site.ctaText }}</a>
    <label for="menu-toggle" class="burger-icon" aria-label="Open menu">
      <span></span><span></span><span></span>
    </label>
  </div>
</header>
