---
layout: layouts/base.njk
---
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Article",
      "headline": "{{ title }}",
      "description": "{{ description }}",
      "datePublished": "{{ date }}",
      "dateModified": "{{ modified or date }}",
      "author": { "@type": "Organization", "name": "CallTeam" },
      "publisher": { "@type": "Organization", "name": "CallTeam", "url": "https://www.callteam.ca" }
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://www.callteam.ca/" },
        { "@type": "ListItem", "position": 2, "name": "Articles", "item": "https://www.callteam.ca/articles/" },
        { "@type": "ListItem", "position": 3, "name": "{{ title }}", "item": "https://www.callteam.ca{{ page.url }}" }
      ]
    }
    {%- if faqs and faqs.length > 0 %}
    ,{
      "@type": "FAQPage",
      "mainEntity": [
        {%- for item in faqs %}
        {
          "@type": "Question",
          "name": "{{ item.question }}",
          "acceptedAnswer": { "@type": "Answer", "text": "{{ item.answer }}" }
        }{% if not loop.last %},{% endif %}
        {%- endfor %}
      ]
    }
    {%- endif %}
  ]
}
</script>

<section class="hero">
  <div>
    {% if category %}<div class="eyebrow">{{ category }}</div>{% endif %}
    <h1>{{ title }}</h1>
    {% if quickAnswer %}<p class="quick-answer"><strong>Quick answer:</strong> {{ quickAnswer }}</p>{% endif %}
  </div>
</section>

<section id="article-body">
  <div class="container article-content">
    {{ content | safe }}
  </div>
</section>

{% if cards and cards.length > 0 %}
<section id="takeaways">
  <div class="container-wide">
    <div class="section-label">Key takeaways</div>
    <h2>{{ cardsHeading or "What you need to know." }}</h2>
    <div class="service-grid">
      {% for card in cards %}
      <div class="service-card">
        <h3>{{ card.title }}</h3>
        <p>{{ card.text }}</p>
      </div>
      {% endfor %}
    </div>
  </div>
</section>
{% endif %}

{% if faqs and faqs.length > 0 %}
<section id="faq">
  <div class="container-wide">
    <div class="section-label">FAQ</div>
    <h2>Common questions.</h2>
    <div class="faq-list">
      {% for item in faqs %}
      <div class="faq-item">
        <h3>{{ item.question }}</h3>
        <p>{{ item.answer }}</p>
      </div>
      {% endfor %}
    </div>
  </div>
</section>
{% endif %}

{% if readNext and readNext.length > 0 %}
<section>
  <div class="container">
    <div class="section-label">Keep reading</div>
    <h2>Related pages.</h2>
    <ul class="help-list">
      {% for item in readNext %}
      <li><a href="{{ item.url }}" class="card-link">{{ item.title }} →</a></li>
      {% endfor %}
    </ul>
  </div>
</section>
{% endif %}

<section class="cta-band">
  <h2>{{ ctaHeading or "Need more qualified B2B conversations?" }}</h2>
  <p>{{ ctaText or "Book a free call and let's look at where your outbound pipeline is breaking." }}</p>
  <a href="{{ ctaUrl or 'https://calendly.com/hello-callteam/30min' }}" class="btn-light" target="_blank" rel="noopener">Book a Free Call</a>
</section>
